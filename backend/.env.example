# Supabase PostgreSQL Database
# Get this from: Supabase Dashboard → Settings → Database → Connection string (URI format)
# Use Transaction mode (port 6543) for IPv4 support on Render
SUPABASE_DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# JWT Secret (change this to a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email credentials for sending verification emails
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Server Configuration
PORT=5000
NODE_ENV=development

# For production on Render, use:
# NODE_ENV=production
# PORT=10000 (Render assigns this automatically)
